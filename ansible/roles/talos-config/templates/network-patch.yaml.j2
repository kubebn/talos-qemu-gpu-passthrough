# Network patch for node {{ node_id | default(inventory_hostname) }}
# Generated by Ansible — do not edit manually
---
apiVersion: v1alpha1
kind: NetworkLinkAliasConfig
name: mgmt
device: eth0
---
apiVersion: v1alpha1
kind: NetworkLinkAliasConfig
name: intranet0
device: enp100s0f0
---
apiVersion: v1alpha1
kind: NetworkLinkAliasConfig
name: intranet1
device: enp105s0f0
---
apiVersion: v1alpha1
kind: NetworkLinkAliasConfig
name: storage0
device: enp100s0f1
---
apiVersion: v1alpha1
kind: NetworkLinkAliasConfig
name: storage1
device: enp105s0f1
---
apiVersion: v1alpha1
kind: NetworkDHCPv4Config
name: mgmt-dhcp
interface: mgmt
---
apiVersion: v1alpha1
kind: NetworkBondConfig
name: bond0
kind: balance-xor
interfaces:
  - intranet0
  - intranet1
addresses:
  - {{ intranet_ip }}/{{ intranet_prefix | default(24) }}
{% if intranet_gateway is defined %}
routes:
  - network: 10.2.0.0/16
    gateway: {{ intranet_gateway }}
{% endif %}
---
apiVersion: v1alpha1
kind: NetworkBondConfig
name: bond1
kind: balance-xor
interfaces:
  - storage0
  - storage1
addresses:
  - {{ storage_ip }}/{{ storage_prefix | default(24) }}
{% if storage_gateway is defined %}
routes:
  - network: 10.3.0.0/16
    gateway: {{ storage_gateway }}
{% endif %}
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: io-worker-{{ node_id | default(inventory_hostname) }}
auto: off
---
apiVersion: v1alpha1
kind: MachineConfig
spec:
  machine:
    kubelet:
      nodeIP:
        validSubnets:
          - {{ intranet_ip }}/32
    nodeLabels:
      topology.kubernetes.io/zone: "rack-1"
      shadeform.io/node-type: "gpu"
      shadeform.io/gpu-model: "h200"
{% if public_ip is defined %}
    nodeAnnotations:
      shadeform.io/public-ip: "{{ public_ip }}"
{% endif %}
